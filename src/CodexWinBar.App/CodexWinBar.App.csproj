<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <UseWPF>true</UseWPF>
    <RootNamespace>CodexWinBar.App</RootNamespace>
    <AssemblyName>CodexWinBar</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>app.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <!-- Multi-size icon packed from upstream Icon.icon/Assets/codexbar.png; also used by the tray. -->
    <EmbeddedResource Include="app.ico" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\CodexWinBar.Core\CodexWinBar.Core.csproj" />
    <ProjectReference Include="..\CodexWinBar.Providers\CodexWinBar.Providers.csproj" />
    <ProjectReference Include="..\CodexWinBar.Widget\CodexWinBar.Widget.csproj" />
  </ItemGroup>
</Project>
